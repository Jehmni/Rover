# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Supabase — get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Firebase Cloud Messaging (HTTP v1) — set via Supabase CLI:
# supabase secrets set GOOGLE_SERVICE_ACCOUNT_JSON='<service-account-json>'
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}

# Internal edge-to-edge auth guard:
# supabase secrets set INTERNAL_NOTIFY_TOKEN='<long-random-secret>'
INTERNAL_NOTIFY_TOKEN=replace-with-long-random-secret
